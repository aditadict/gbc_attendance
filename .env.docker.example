APP_NAME="Global Bahtera College HRIS"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://gbc.atlasdigitalize.com

LOG_CHANNEL=stderr
LOG_LEVEL=warning

# --- Laravel DB (app container) ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=gbc_hris
DB_USERNAME=gbc_hris
DB_PASSWORD=GANTI_PASSWORD_KUAT

# --- PostgreSQL container (harus sama dengan DB_* di atas) ---
POSTGRES_DB=gbc_hris
POSTGRES_USER=gbc_hris
POSTGRES_PASSWORD=GANTI_PASSWORD_KUAT

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local
FILAMENT_FILESYSTEM_DISK=local
